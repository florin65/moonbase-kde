          MODULE=gwenview
         VERSION=26.04.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=https://download.kde.org/stable/release-service/$VERSION/src/
      SOURCE_VFY=sha256:45aa9d633a867567dae07d75e43421e8f156b176755f8f81b888597955b115a9
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://www.kde.org/applications/graphics/gwenview/
         ENTERED=20110813
         UPDATED=20260416
           SHORT="Image viewer for KDE"

cat << EOF
Gwenview is a fast and easy to use image viewer for KDE.
Features
    Supports simple image manipulations: rotate, mirror, flip, and resize.
    Supports basic file management actions such as copy, move, delete, and
    others.
    Functions both as a standalone application and an embedded viewer in the
    Konqueror web browser.
    Can be extended using KIPI plugins.
EOF
