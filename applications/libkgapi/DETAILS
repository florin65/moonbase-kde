          MODULE=libkgapi
         VERSION=26.04.0
          SOURCE=$MODULE-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:fa211ea7450d3ac3917850fa404679e6c2a7f2e53fe542447dad2b1a9eb124b6
        WEB_SITE=http://www.progdan.cz/2012/05/libkgoogle-libkgapi/
