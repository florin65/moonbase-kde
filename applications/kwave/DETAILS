          MODULE=kwave
         VERSION=26.04.0
          SOURCE=kwave-$VERSION.tar.xz
      SOURCE_URL=$KDE_URL/stable/release-service/$VERSION/src
      SOURCE_VFY=sha256:aca5c3f95d32d737026e04eeba161851b7855990f0f4aa2c4af7033a68c536fc
   MODULE_PREFIX=${KDE_INSTALL_DIR:-/usr}
        WEB_SITE=http://kwave.sourceforge.net
         ENTERED=20090426
         UPDATED=20260416
           SHORT="Sound editor designed for the KDE"

cat << EOF
With Kwave you can edit many sorts of wav-files including multi-channel files.
You are able to alter and play back each channel on its own.
Kwave also includes many plugins (most are still under development) to
transform the wave-file in several ways and presents a graphical view with a
complete zoom and scroll capability.
EOF
